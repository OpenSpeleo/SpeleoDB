# General
# ------------------------------------------------------------------------------
USE_DOCKER=True
IPYTHONDIR=/app/.ipython

# Redis
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# Celery
# ------------------------------------------------------------------------------

# GitLab (local Compose service)
# ------------------------------------------------------------------------------
GITLAB_GROUP_ID=2
GITLAB_GROUP_NAME=speleodb
GITLAB_HOST_URL=localhost:9080
GITLAB_TOKEN=debug

# Map rendering (a real token may be supplied for Mapbox-backed local views)
# ------------------------------------------------------------------------------
MAPBOX_API_TOKEN=unused-local-token

# RustFS / S3-compatible local object storage
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=access_key
AWS_SECRET_ACCESS_KEY=secret_key
AWS_STORAGE_BUCKET_NAME=speleodb
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_CUSTOM_DOMAIN=localhost:9000/speleodb

# Flower
# ------------------------------------------------------------------------------
CELERY_FLOWER_USER=debug
CELERY_FLOWER_PASSWORD=debug

# Django
# -------------------------------------------------------------------------------
DJANGO_DEBUG=True
DJANGO_SECRET_KEY="1!(kim5&o=o6iu8gdmp%b4r6+pphg%_kgt*nd^k=k#88d6vyq3"
