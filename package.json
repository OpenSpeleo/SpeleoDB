{
  "name": "speleodb",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "npm run dev",
    "build": "npm run build:clean && npm run build:assets",
    "build:clean": "rimraf ./speleodb/common/static/speleodb/vite/ ./speleodb/common/static/speleodb/css/app.css ./frontend_public/static/css/style.css ./frontend_private/static/private/css/style.css ./frontend_private/static/private/js/dist/ ./frontend_public/static/js/dist/",
    "build:assets": "vite build --mode production",
    "dev": "vite build --watch --mode development",
    "pre-commit": "npm run build",
    "update": "ncu --target minor -u && npm install && npx update-browserslist-db@latest",
    "lint:js": "eslint \"vite.config.mjs\" \"scripts/**/*.mjs\" \"frontend_common/**/*.js\" \"frontend_private/static/private/js/**/*.js\" \"frontend_public/static/js/**/*.js\" \"frontend_errors/static/js/**/*.js\" --ignore-pattern \"frontend_private/static/private/js/dist/**\" --ignore-pattern \"frontend_private/static/private/js/vendors/**\" --ignore-pattern \"frontend_public/static/js/dist/**\" --ignore-pattern \"frontend_public/static/js/vendors/**\" --report-unused-disable-directives-severity off --max-warnings=0",
    "lint:js:fix": "npm run lint:js -- --fix",
    "test:js": "vitest run --config ./vitest.config.mjs",
    "test:js:watch": "vitest --config ./vitest.config.mjs",
    "test:assets-watch": "node scripts/verify-vite-watch.mjs"
  },
  "devDependencies": {
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "npm-check-updates": "^22.2.9",
    "rimraf": "^6.1.3",
    "tailwindcss": "4.3.2",
    "vite": "8.1.4",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
